# 复制此文件为 .env 并填入你的真实配置
# cp .env.example .env

# === 必填 ===
DEEPSEEK_API_KEY=sk-你的deepseek-api-key

# === 数据库 ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=video_downloader

# === 可选 ===
# JWT_SECRET_KEY=自定义密钥（不填则自动生成）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=你的邮箱@qq.com
# SMTP_PASSWORD=邮箱授权码
